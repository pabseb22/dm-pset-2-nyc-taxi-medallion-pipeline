if 'data_loader' not in globals():
    from mage_ai.data_preparation.decorators import data_loader
if 'test' not in globals():
    from mage_ai.data_preparation.decorators import test

import os
from io import BytesIO
import pandas as pd
import requests


def month_range(start_month: str, end_month: str):
    start = pd.Period(start_month, freq='M')
    end = pd.Period(end_month, freq='M')

    if start > end:
        raise ValueError('INGEST_START_MONTH cannot be greater than INGEST_END_MONTH')

    return [m.strftime('%Y-%m') for m in pd.period_range(start=start, end=end, freq='M')]


def build_trip_url(base_url: str, service_type: str, year_month: str) -> str:
    return f'{base_url}/{service_type}_tripdata_{year_month}.parquet'


def download_parquet(url: str) -> pd.DataFrame:
    response = requests.get(url, timeout=120)
    if response.status_code == 404:
        raise FileNotFoundError(f'File not found: {url}')
    response.raise_for_status()
    return pd.read_parquet(BytesIO(response.content))


@data_loader
def load_data(*args, **kwargs):
    base_url = os.getenv('NYC_TLC_BASE_URL')
    zone_url = os.getenv('NYC_TLC_ZONE_URL')
    start_month = os.getenv('INGEST_START_MONTH')
    end_month = os.getenv('INGEST_END_MONTH')

    if not base_url:
        raise ValueError('NYC_TLC_BASE_URL is missing')
    if not zone_url:
        raise ValueError('NYC_TLC_ZONE_URL is missing')
    if not start_month or not end_month:
        raise ValueError('INGEST_START_MONTH / INGEST_END_MONTH are missing')

    ingest_ts = pd.Timestamp.utcnow().tz_localize(None)
    service_types = ['yellow', 'green']

    trip_dfs = {
        'yellow': [],
        'green': [],
    }
    audit_rows = []

    for ym in month_range(start_month, end_month):
        for service_type in service_types:
            url = build_trip_url(base_url, service_type, ym)

            try:
                df = download_parquet(url)

                df['ingest_ts'] = ingest_ts
                df['source_month'] = ym
                df['service_type'] = service_type

                df.columns = [c.lower() for c in df.columns]
                trip_dfs[service_type].append(df)

                audit_rows.append({
                    'year_month': ym,
                    'service_type': service_type,
                    'status': 'loaded',
                    'row_count': int(len(df)),
                    'source_url': url,
                    'error_message': None,
                    'ingest_ts': ingest_ts,
                })

            except FileNotFoundError as e:
                audit_rows.append({
                    'year_month': ym,
                    'service_type': service_type,
                    'status': 'missing',
                    'row_count': 0,
                    'source_url': url,
                    'error_message': str(e),
                    'ingest_ts': ingest_ts,
                })

            except Exception as e:
                audit_rows.append({
                    'year_month': ym,
                    'service_type': service_type,
                    'status': 'failed',
                    'row_count': 0,
                    'source_url': url,
                    'error_message': str(e)[:1000],
                    'ingest_ts': ingest_ts,
                })

    yellow_df = pd.concat(trip_dfs['yellow'], ignore_index=True) if trip_dfs['yellow'] else pd.DataFrame()
    green_df = pd.concat(trip_dfs['green'], ignore_index=True) if trip_dfs['green'] else pd.DataFrame()

    zones_df = pd.read_csv(zone_url)
    zones_df.columns = [c.lower() for c in zones_df.columns]
    zones_df['ingest_ts'] = ingest_ts

    audit_df = pd.DataFrame(audit_rows)
    audit_df.columns = [c.lower() for c in audit_df.columns]

    if yellow_df.empty and green_df.empty:
        raise ValueError('No trip files were loaded for any service/month')

    print("yellow rows:", len(yellow_df))
    print("green rows:", len(green_df))
    print("zones rows:", len(zones_df))
    print("audit rows:", len(audit_df))

    return {
        'yellow_trips_df': yellow_df,
        'green_trips_df': green_df,
        'zones_df': zones_df,
        'audit_df': audit_df,
    }


@test
def test_output(output, *args) -> None:
    assert output is not None, 'The output is undefined'

    required_keys = ['yellow_trips_df', 'green_trips_df', 'zones_df', 'audit_df']
    for key in required_keys:
        assert key in output, f'Missing {key}'

    audit_df = output['audit_df']
    zones_df = output['zones_df']
    yellow_df = output['yellow_trips_df']
    green_df = output['green_trips_df']

    assert not audit_df.empty, 'audit_df is empty'
    assert 'year_month' in audit_df.columns, 'year_month missing in audit_df'
    assert 'service_type' in audit_df.columns, 'service_type missing in audit_df'
    assert 'status' in audit_df.columns, 'status missing in audit_df'

    assert 'locationid' in zones_df.columns, 'locationid missing in zones_df'

    if not yellow_df.empty:
        assert 'ingest_ts' in yellow_df.columns, 'ingest_ts missing in yellow_trips_df'
        assert 'source_month' in yellow_df.columns, 'source_month missing in yellow_trips_df'
        assert 'service_type' in yellow_df.columns, 'service_type missing in yellow_trips_df'

    if not green_df.empty:
        assert 'ingest_ts' in green_df.columns, 'ingest_ts missing in green_trips_df'
        assert 'source_month' in green_df.columns, 'source_month missing in green_trips_df'
        assert 'service_type' in green_df.columns, 'service_type missing in green_trips_df'
version: 2

models:
  - name: dim_date
    columns:
      - name: date_key
        tests:
          - not_null
          - unique

  - name: dim_zone
    columns:
      - name: zone_id
        tests:
          - not_null
          - unique

  - name: dim_service_type
    columns:
      - name: service_type_key
        tests:
          - not_null
          - unique

  - name: dim_payment_type
    columns:
      - name: payment_type_key
        tests:
          - not_null
          - unique

  - name: fct_trips
    columns:
      - name: trip_key
        tests:
          - not_null
          - unique

      - name: pickup_date_key
        tests:
          - not_null

      - name: pickup_zone_id
        tests:
          - not_null

      - name: dropoff_zone_id
        tests:
          - not_null
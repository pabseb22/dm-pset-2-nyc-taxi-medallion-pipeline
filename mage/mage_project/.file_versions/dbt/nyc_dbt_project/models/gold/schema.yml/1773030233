version: 2

models:
  - name: dim_date
    columns:
      - name: date_key
        tests:
          - not_null
          - unique

  - name: dim_zone
    columns:
      - name: zone_id
        tests:
          - not_null
          - unique

  - name: dim_service_type
    columns:
      - name: service_type_key
        tests:
          - not_null
          - unique

  - name: dim_payment_type
    columns:
      - name: payment_type_key
        tests:
          - not_null
          - unique

  - name: fct_trips
    columns:
      - name: trip_key
        tests:
          - not_null
          - unique

      - name: pickup_date_key
        tests:
          - not_null
          - relationships:
              to: ref('dim_date')
              field: date_key

      - name: pickup_zone_id
        tests:
          - not_null
          - relationships:
              to: ref('dim_zone')
              field: zone_id

      - name: dropoff_zone_id
        tests:
          - not_null
          - relationships:
              to: ref('dim_zone')
              field: zone_id

      - name: service_type_key
        tests:
          - relationships:
              to: ref('dim_service_type')
              field: service_type_key

      - name: payment_type_key
        tests:
          - relationships:
              to: ref('dim_payment_type')
              field: payment_type_key
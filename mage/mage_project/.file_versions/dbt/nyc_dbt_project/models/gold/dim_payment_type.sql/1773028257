WITH payment_types AS (

    SELECT DISTINCT
        payment_type
    FROM {{ ref('silver_trips_unified') }}
    WHERE payment_type IS NOT NULL

)

SELECT
    CAST(payment_type AS INTEGER) AS payment_type_key,
    CASE CAST(payment_type AS INTEGER)
        WHEN 1 THEN 'Credit card'
        WHEN 2 THEN 'Cash'
        WHEN 3 THEN 'No charge'
        WHEN 4 THEN 'Dispute'
        WHEN 5 THEN 'Unknown'
        WHEN 6 THEN 'Voided trip'
        ELSE 'Other'
    END AS payment_type_desc
FROM payment_types